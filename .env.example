# ── LLM (OpenRouter / DeepSeek) ─────────────────────────────────────────────
OPENAI_API_KEY=sk-or-v1-...your-openrouter-key...
OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_MODEL=deepseek/deepseek-v4-flash
LLM_MAX_TOKENS=7000
LLM_TEMPERATURE=0.6

# ── Reranker (2-й этап RAG, тот же OpenRouter-ключ) ──────────────────────────
RERANK_MODEL=cohere/rerank-4-fast
RERANK_ENABLED=true
RERANK_CANDIDATES=24

# ── Внешние научные источники (умный парсер базы знаний) ─────────────────────
EXTERNAL_SOURCES=openalex,crossref,semantic_scholar
# MP_API_KEY=                 # Materials Project — включает коннектор свойств материалов
# SEMANTIC_SCHOLAR_API_KEY=   # снимает лимит 429 у Semantic Scholar
CONTACT_MAILTO=hypofactory@example.com

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=hypo
POSTGRES_PASSWORD=hypo_secret
POSTGRES_DB=hypofactory
DATABASE_URL=postgresql://hypo:hypo_secret@db:5432/hypofactory

# ── App ─────────────────────────────────────────────────────────────────────
SEED_DEMO=true
FLASK_ENV=production
