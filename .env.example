# ── LLM (OpenRouter / DeepSeek) ─────────────────────────────────────────────
OPENAI_API_KEY=sk-or-v1-
OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_MODEL=deepseek/deepseek-v4-flash
LLM_MAX_TOKENS=7000
LLM_TEMPERATURE=0.6

# ── Гибридный поиск: BM25 (лексика) + dense-ретривер bge-m3 (семантика) ──────
EMBED_MODEL=baai/bge-m3
EMBED_ENABLED=true
HYBRID_BM25_WEIGHT=1.0
HYBRID_DENSE_WEIGHT=1.0

# ── Reranker (2-й этап RAG, тот же OpenRouter-ключ) ──────────────────────────
RERANK_MODEL=cohere/rerank-4-fast
RERANK_ENABLED=true
RERANK_CANDIDATES=24

# ── Внешние научные источники (умный парсер базы знаний) ─────────────────────
EXTERNAL_SOURCES=openalex,crossref,semantic_scholar
# MP_API_KEY=                 # Materials Project — включает коннектор свойств материалов
# SEMANTIC_SCHOLAR_API_KEY=   # снимает лимит 429 у Semantic Scholar
CONTACT_MAILTO=hypofactory@example.com
# AI parser review (independent from hypothesis generator)
AI_DEFAULT_PROVIDER=noop
AI_LLM_PROVIDER=noop
AI_EMBEDDING_PROVIDER=noop
AI_EXTRACTION_PROVIDER=noop
AI_API_KEY=sk-or-v1-
AI_API_BASE=noop
AI_PARSER_REVIEW_MODEL=qwen/qwen3-4b-instruct-2507
AI_PARSER_REVIEW_MAX_TOKENS=900
AI_PARSER_REVIEW_INPUT_CHARS=14000
AI_PARSER_REVIEW_TEMPERATURE=0.0

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=hypo
POSTGRES_PASSWORD=hypo_secret
POSTGRES_DB=hypofactory
DATABASE_URL=postgresql://hypo:hypo_secret@db:5432/hypofactory

# ── App ─────────────────────────────────────────────────────────────────────
SEED_DEMO=true
FLASK_ENV=production
