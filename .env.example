# ── LLM (OpenRouter / DeepSeek) ─────────────────────────────────────────────
OPENAI_API_KEY=sk-or-v1-
OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_MODEL=deepseek/deepseek-v4-flash

LLM_MAX_TOKENS=7000
LLM_TEMPERATURE=0.6

# AI parser review (independent from hypothesis generator)
AI_DEFAULT_PROVIDER=noop
AI_LLM_PROVIDER=noop
AI_EMBEDDING_PROVIDER=noop
AI_EXTRACTION_PROVIDER=noop
AI_API_KEY=sk-or-v1-
AI_API_BASE=noop
AI_PARSER_REVIEW_MODEL=qwen/qwen3-4b-instruct-2507
AI_PARSER_REVIEW_MAX_TOKENS=900
AI_PARSER_REVIEW_INPUT_CHARS=14000
AI_PARSER_REVIEW_TEMPERATURE=0.0

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=hypo
POSTGRES_PASSWORD=hypo_secret
POSTGRES_DB=hypofactory
DATABASE_URL=postgresql://hypo:hypo_secret@db:5432/hypofactory

# ── App ─────────────────────────────────────────────────────────────────────
SEED_DEMO=true
FLASK_ENV=production
